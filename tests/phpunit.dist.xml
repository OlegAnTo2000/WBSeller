<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.0/phpunit.xsd"
	bootstrap="bootstrap.php"
	cacheResult="false"
	colors="true"
>
	<testsuites>
		<testsuite name="Unit">
			<directory>Unit</directory>
			<file>TokenTest.php</file>
		</testsuite>
		<testsuite name="Integration">
			<directory>ApiClient</directory>
		</testsuite>
	</testsuites>
	<php>
		<env name="APIKEY"  value="" />
		<env name="APIKEY_READONLY"  value="" />
		<env name="CAMPAIGN_ID"  value="" />
		<env name="NM_ID"  value="" />
		<env name="DATE_FROM"  value="" />
		<env name="DATE_TO"  value="" />
	</php>
</phpunit>
