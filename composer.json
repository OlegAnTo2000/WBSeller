{
    "name": "oleganto2000/wbseller",
    "description": "Wildberries API client, fork from https://github.com/Dakword/WBSeller",
    "keywords": ["wildberries", "api", "openapi", "php"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit"          : "12",
        "phpstan/phpstan"          : "^2.1",
        "friendsofphp/php-cs-fixer": "^3.86"
    },
    "scripts": {
        "test": "@test:unit",
        "test:unit": "phpunit -c tests/phpunit.dist.xml --testsuite Unit",
        "test:integration": "phpunit -c tests/phpunit.dist.xml --testsuite Integration",
        "test:all": "phpunit -c tests/phpunit.dist.xml",
        "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=4G"
    },
    "autoload": {
        "psr-4": {
            "Dakword\\WBSeller\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dakword\\WBSeller\\Tests\\": "tests/"
        }
    }
}
