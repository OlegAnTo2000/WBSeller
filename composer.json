{
    "name": "oleganto2000/wbseller",
    "description": "Wildberries API client, fork from https://github.com/Dakword/WBSeller",
    "keywords": ["wildberries", "api", "openapi", "php"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit"          : "12",
        "phpstan/phpstan"          : "^2.1",
        "friendsofphp/php-cs-fixer": "^3.86"
    },
    "config": {
        "process-timeout": 1800
    },
    "scripts": {
        "test": "@test:unit",
        "test:unit": "@php -d memory_limit=512M vendor/bin/phpunit -c tests/phpunit.dist.xml --testsuite Unit --colors=always --testdox --testdox-summary --display-errors --display-warnings --display-deprecations --display-notices --display-incomplete --display-skipped",
        "test:integration": "@php -d memory_limit=512M vendor/bin/phpunit -c tests/phpunit.xml --testsuite Integration --colors=always --testdox --testdox-summary --display-errors --display-warnings --display-deprecations --display-notices --display-incomplete --display-skipped",
        "test:integration:section": "@test:integration --filter",
        "test:integration:adv": "@test:integration --filter AdvTest",
        "test:integration:analytics": "@test:integration --filter \"Analytics|Analitics\"",
        "test:integration:calendar": "@test:integration --filter CalendarTest",
        "test:integration:common": "@test:integration --filter Common",
        "test:integration:content": "@test:integration --filter Content",
        "test:integration:feedbacks": "@test:integration --filter Feedbacks",
        "test:integration:marketplace": "@test:integration --filter Marketplace",
        "test:integration:prices": "@test:integration --filter PricesTest",
        "test:integration:questions": "@test:integration --filter Questions",
        "test:integration:recommends": "@test:integration --filter RecommendsTest",
        "test:integration:statistics": "@test:integration --filter StatisticsTest",
        "test:integration:supplies": "@test:integration --filter SuppliesTest",
        "test:integration:tariffs": "@test:integration --filter TariffsTest",
        "test:all": "@php -d memory_limit=512M vendor/bin/phpunit -c tests/phpunit.xml --colors=always --testdox --testdox-summary --display-errors --display-warnings --display-deprecations --display-notices --display-incomplete --display-skipped",
        "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=4G"
    },
    "autoload": {
        "psr-4": {
            "Dakword\\WBSeller\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dakword\\WBSeller\\Tests\\": "tests/"
        }
    }
}
